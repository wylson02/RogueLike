{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Les Sceaux de l'Abime",
  "version": "1.0.0",
  "identifier": "com.wylson.sceauxdelabime",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Les Sceaux de l'Abîme",
        "width": 1280,
        "height": 720,
        "minWidth": 960,
        "minHeight": 540,
        "resizable": true,
        "center": true,
        "backgroundColor": "#07060a"
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns",
      "icons/icon.png"
    ]
  }
}
